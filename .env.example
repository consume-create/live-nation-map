# =============================================================================
# Sanity CMS – environment (do not commit; add your credentials below)
# =============================================================================

# --- Frontend (Vite app: map + detail pages) ---
VITE_SANITY_PROJECT_ID=4hqkvrv9
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-05-01
# Optional: create a token with Viewer role at sanity.io/manage → API → Tokens
# Required only if your dataset has restricted access.
VITE_SANITY_READ_TOKEN=
VITE_SANITY_USE_CDN=true

# --- Sanity Studio (when running from sanity/ folder) ---
# Copy this file to sanity/.env if you run Studio from sanity/
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production
# SANITY_STUDIO_HOST=live-nation-map
